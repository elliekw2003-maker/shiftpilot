datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum TeamMemberRole {
  MANAGER
  EMPLOYEE
}

enum RosterSlotStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum ShiftAssignmentStatus {
  ASSIGNED
  CANCELLED
  COMPLETED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdTeams    Team[]       @relation("TeamCreatedBy")
  teamMemberships TeamMember[]
}

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  timezone    String   @default("Australia/Melbourne")
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User         @relation("TeamCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  members     TeamMember[]
  positions   Position[]
  rosterSlots RosterSlot[]
}

model TeamMember {
  id          String         @id @default(uuid()) @db.Uuid
  teamId      String         @db.Uuid
  userId      String         @db.Uuid
  role        TeamMemberRole @default(EMPLOYEE)
  displayName String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdRosterSlots  RosterSlot[]      @relation("RosterSlotCreatedBy")
  employeeAssignments ShiftAssignment[] @relation("EmployeeAssignments")
  createdAssignments  ShiftAssignment[] @relation("AssignmentsCreatedBy")

  @@unique([teamId, userId])
  @@index([userId])
}

model Position {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  rosterSlots RosterSlot[]

  @@unique([teamId, name])
}

model RosterSlot {
  id            String           @id @default(uuid()) @db.Uuid
  teamId        String           @db.Uuid
  positionId    String           @db.Uuid
  startAt       DateTime
  endAt         DateTime
  requiredCount Int
  status        RosterSlotStatus @default(DRAFT)
  createdById   String           @db.Uuid
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  team        Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  position    Position          @relation(fields: [positionId], references: [id], onDelete: Restrict)
  createdBy   TeamMember        @relation("RosterSlotCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignments ShiftAssignment[]

  @@index([teamId, startAt])
  @@index([positionId])
  @@index([createdById])
}

model ShiftAssignment {
  id           String                @id @default(uuid()) @db.Uuid
  rosterSlotId String                @db.Uuid
  employeeId   String                @db.Uuid
  assignedById String                @db.Uuid
  status       ShiftAssignmentStatus @default(ASSIGNED)
  assignedAt   DateTime              @default(now())
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  rosterSlot RosterSlot @relation(fields: [rosterSlotId], references: [id], onDelete: Cascade)
  employee   TeamMember @relation("EmployeeAssignments", fields: [employeeId], references: [id], onDelete: Restrict)
  assignedBy TeamMember @relation("AssignmentsCreatedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([rosterSlotId, employeeId])
  @@index([employeeId])
  @@index([assignedById])
}
